                <div type="edition" xml:lang="okz-Latn" rendition="class:83231 maturity:83213">
                   <p><milestone type="pagelike" unit="item" n="S"/><label xml:lang="eng">Southern doorjamb</label>
                      <gap reason="lost" extent="unknown" unit="line"/><!-- kuch: GC : On distingue les mots kaṁmrateṅ, vāp, loñ, khloñ, khñuṁ, tai, sruk, caṁnāṁ, vvaṁ āc ti, śivaliṅga. -->
                   </p>
                   <p><milestone type="pagelike" unit="item" n="N"/><label xml:lang="eng">Northern doorjamb</label>
                      <lb n="N1"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N2"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N3"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N4"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N5"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N6"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N7"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N8"/>khloñ vnaṁ vraḥ kaṁmrateṅ Añ śivapāda {14}
                      <lb n="N9"/>saṁtap nuv sabhā ta stap vyavahāra phoṅ pre {13}
                      <lb n="N10"/>yau 3 nuv rddeḥ dṅan ta 4 ta syaṅ ta pravai[ṇi] {12}
                      <lb n="N11"/>pi dār roḥ man steñ Añ Ācāryya khloñ vnaṁ {15}
                      <lb n="N12"/>phoṅ ta stap vyavahāra pre vāp {17} [Aṁ]-
                      <lb n="N13"/>pall noḥ vyat diḥ qyat leh Añ khnuṁ {17}
                      <lb n="N14"/>h @ gi muh ta mān ta Añ khñuṁ sre Añ {18}
                      <lb n="N15"/>vraḥ kaṁmrateṅ Añ śivaliṅga {20}
                      <lb n="N16"/>pre dār sre {2} Oy ta vraḥ kaṁmra[teṅ] {18}
                      <lb n="N17"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N18"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N19"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N20"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N21"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N22"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N23"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N24"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N25"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N26"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N27"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N28"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N29"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N30"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N31"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N32"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N33"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N34"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N35"/><gap reason="lost" extent="unknown" unit="character"/>
                      <lb n="N36"/>{26} ta kulapati vraḥ
                      <lb n="N37"/>{21} jyaṅ 8 daṁṅan ti Oy ta kaṁmra-
                      <lb n="N38"/>[teṅ] {20} thve tala parvvata vraḥ yajña pi Oy ta vraḥ
                      <lb n="N39"/>{17} putra raṁlik ta kaṁmrateṅ Añ vraḥ guru mann neḥ vu-
                      <lb n="N40"/>[di] {15} Oy ta kaṁmrateṅ Añ pi kaṁmrateṅ Añ Oy cval
                      <lb n="N41"/>{9} kaṁmrateṅ Añ vrāhmaṇa purohita @ noḥ vudi noḥ nai vraḥ kaṁmrateṅ
                      <lb n="N42"/>{7} chok phlāṅ @ ta khloñ vala addhyāpaka khmi vrai Anlom lvann pi Oy ta vraḥ kaṁmrate-
                      <lb n="N43"/>ṅ {6}
                      </p>
