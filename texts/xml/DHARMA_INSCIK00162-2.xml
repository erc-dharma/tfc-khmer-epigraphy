                      <lb n="22"/>bagavataś śrījayavarmmadeveṇdrādhirājena tribhubanasthāṇanirmmike-
                      <lb n="23"/>na mahadbhutayaśavividheṇa parākramena saha babhūva <g ref="sym:circle" type="punctuation">.</g> yasya basu-
                      <lb n="24"/>ndha[ra] - - - - - - - - - - bhagavataś śrītripurāntakeśvare bhaktyādiśat <g ref="sym:circle" type="punctuation">.</g></p>
                   <lg n="10" met="anuṣṭubh">
<l n="a"><lb n="25"/><milestone unit="column" n="a"/>pūjārtham asya yat dattaṁ</l>
                      <l n="b"><milestone unit="column" n="b"/>hemarūpyādikan dhaṇaṁ</l>
<l n="c"><lb n="26"/><milestone unit="column" n="a"/>haranti ye na kiñ cit te</l>
                      <l n="d"><milestone unit="column" n="b"/>basanti narake ciram <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="11" met="anuṣṭubh">
<l n="a"><lb n="27"/><milestone unit="column" n="a"/>pūjārtham asyayatvaddhaṁ</l>
                      <l n="b"><milestone unit="column" n="b"/>pālayatneṇa te naraḥ</l>
<l n="c"><lb n="28"/><milestone unit="column" n="a"/>sugatiṁ yānti svakulaiḥ</l>
                      <l n="d"><milestone unit="column" n="b"/>svarggaṁ yānti ciram vaset <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
     <p xml:lang="okz-Latn">
        <lb n="29"/>{2} śāsana dhūli vraḥ pāda dhūli jeṅ vraḥ kaṁmrateṅ Añ
        <lb n="30"/>{2} saṁ nu rājapunya vvaṁ jā pi dār vrihi vvaṁ jā pi dār paryyaṅ
