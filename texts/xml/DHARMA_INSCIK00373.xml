                <div type="edition" xml:lang="okz-Latn" rendition="class:83231 maturity:83213">
<p><milestone type="pagelike" unit="face" n="A"/><label xml:lang="eng">Face A</label>
   <lb n="A1"/>neḥ bhūmi ta roḥh neḥ vvaṁ Āc ti mān <gap reason="lost" quantity="5" unit="character"/> ya nu qnak ta gi viṣaya phoṅ ta vāda <g type="circleSmall">.</g> pratyaya
   <lb n="A2"/><gap reason="lost" quantity="6" unit="character"/> nā mok pan<supplied reason="lost">dva</supplied>l loñ bhadraśiva loñ vrahmaśiva loñ ravi loñ candra
</p>
                   <p><milestone type="pagelike" unit="face" n="B"/><label xml:lang="eng">Face B</label>
   <lb n="B1"/><gap reason="lost" quantity="10" unit="character"/> nirṇṇaya toy Uttamasāha <g type="circleSmall">.</g> man vāp pān<supplied reason="lost">dava</supplied> <gap reason="lost" quantity="3" unit="character"/>
   <lb n="B2"/><gap reason="lost" quantity="15" unit="character"/> svaṁ prasāda gi pi ros ta gi pi vvaṁ vraḥ pre <gap reason="lost" quantity="3" unit="character"/>
                      <lb n="B3"/><gap reason="lost" quantity="14" unit="character"/> vraḥ mattavāraṇa <g type="circleSmall">.</g> pre cār Iss śākha saṁnva<supplied reason="lost">t</supplied> <gap reason="lost" quantity="1" unit="character"/>
                      <lb n="B4"/><gap reason="lost" quantity="6" unit="character"/> pre pratyaya dau saṅ gol praśasta viṅ ta gi bhūmi ta roḥh neḥh <g type="circleSmall">.</g> pre ni
</p>
                   <p><milestone type="pagelike" unit="face" n="C"/><label xml:lang="eng">Face C</label>
   <lb n="C1"/>yama daha mān<unclear>·</unclear> <gap reason="lost" quantity="2" unit="character"/>
   <lb n="C2"/>vāp· pāndava ta thve vāda bhū<lb 
      n="C3" break="no"/>mi neḥ ley· pre saṁlā<lb 
         n="C4" break="no"/>p· qyat si stāp· vyavahāra
   <lb n="C5"/>ley<unclear>·</unclear> ta qnau nā mā<lb 
      n="C6" break="no"/>n· vraḥ karuṇā <gap reason="lost" quantity="4" unit="character"/>
   <lb n="C7"/>neḥha <unclear><g type="circleSmall">.</g></unclear> mratāñ· khlo<lb 
      n="C8" break="no"/>ñ· śrī vīrendravarmma <g type="circleSmall">.</g> mratā<lb 
         n="C9" break="no"/>ñ· khloñ· śrī vīrendrādhi<lb 
            n="C10" break="no"/>pativarmma <g type="circleSmall">.</g> mratāñ<unclear>·</unclear> khlo<supplied reason="lost">ñ·</supplied>
   <lb n="C11"/>śrī mahīdharavarmma <g type="circleSmall">.</g> <supplied reason="lost">mratā</supplied><lb 
      n="C12" break="no"/>ñ· khloñ· śrī jayā<supplied reason="lost">yu</supplied><lb 
         n="C13" break="no"/>ddhavarmma <g type="circleSmall">.</g> mratāñ<unclear>·</unclear> khlo<supplied reason="lost">ñ·</supplied>
   <lb n="C14"/>śrī narapatīndrava<supplied reason="lost">rmma <g type="circleSmall">.</g> mratā</supplied><lb 
      n="C15" break="no"/>ñ· khloñ· śrī dhara<gap reason="lost" quantity="3" unit="character"/><lb 
         n="C16" break="no"/>varmma <g type="circleSmall">.</g> mratāñ· śrī <gap reason="lost" quantity="3" unit="character"/><lb 
            n="C17" break="no"/>rimathana <g type="circleSmall">.</g> mratāñ<unclear>·</unclear> <gap reason="lost" quantity="3" unit="character"/><lb 
               n="C18" break="no"/>ndrārimathana <g type="circleSmall">.</g> mratā<supplied reason="lost">ñ·</supplied> <gap reason="lost" quantity="3" unit="character"/><lb 
                  n="C19" break="no"/>nakesari <g type="circleSmall">.</g> mratā<supplied reason="lost">ñ· śrī</supplied>
   <lb n="C20"/>dharaṇīndraparākrama <g type="circleSmall">.</g> <supplied reason="lost">mra</supplied><lb 
      n="C21" break="no"/>tāñ· śrī dharaṇīndropa<lb 
         n="C22" break="no"/>kalpa <g type="circleSmall">.</g> kaṁsteṅ· Añ<unclear>·</unclear> guṇa<lb 
            n="C23" break="no"/>doṣa <g type="circleSmall">.</g> mratāñ· śrī mahe<lb 
               n="C24" break="no"/>ndrasiṅha <g type="circleSmall">.</g> mratāñ· śrī vi<lb 
                  n="C25" break="no"/>kramasiṅha <g type="circleSmall">.</g> mratā<lb 
                     n="C26" break="no"/>ñ· śrī rajendrasiṅha <g type="circleSmall">.</g> mratā<lb 
                        n="C27" break="no"/>ñ· śrī parākramasiṅha <g type="circleSmall">.</g> ri
   <lb n="C28"/>vraḥ sabhā ta paṅgaṁ th<unclear>p</unclear><supplied reason="lost">vaṅ· nive</supplied><lb 
      n="C29" break="no"/>dana <g type="circleSmall">.</g> mratāñ· <gap reason="lost" quantity="4" unit="character"/>
   <lb n="C30"/>tabhaktivallabha <g type="circleSmall">.</g> <gap reason="lost" quantity="4" unit="character"/>
   <lb n="C31"/>vrahmayogis<seg type="component" subtype="vowel"><gap reason="illegible" quantity="1" unit="character"/></seg> <gap reason="lost" quantity="4" unit="character"/>
   <lb n="C32"/>vāp· rudrabhāva <gap reason="lost" quantity="3" unit="character"/> <supplied reason="lost">vya</supplied><lb 
      n="C33" break="no"/>vahāra ta vāp ta <gap reason="lost" quantity="3" unit="character"/>
   <lb n="C34"/>taṁ sruk kaṁveṅ ta <gap reason="lost" quantity="3" unit="character"/>
   <lb n="C35"/>noḥha chvāt· ma<gap reason="lost" quantity="3" unit="character"/><lb 
      n="C36" break="no"/>la <g type="circleSmall">.</g> pandval<supplied reason="omitted">·</supplied> vraḥ śāsa<supplied reason="lost">na</supplied>
   <lb n="C37"/>Oy· bhūmi ta roḥha
   <lb n="C38"/>neḥha viṅ ta vāp tapoma<lb 
      n="C39" break="no"/>ya <g type="circleSmall">.</g>
</p>
