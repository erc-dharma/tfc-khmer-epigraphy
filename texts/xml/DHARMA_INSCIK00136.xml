   <text xml:space="preserve">
        <body>
                <div type="edition" xml:lang="san-Latn" rendition="class:83231 maturity:83213">
<lg n="1" met="anuṣṭubh"><milestone type="pagelike" unit="face" n="A"/><label xml:lang="eng">Face A</label>
<l n="a"><lb n="A1"/><milestone unit="column" n="a"/>====-++=</l>
<l n="b"><milestone unit="column" n="b"/>[u]jv[ala]t tamasaḥ param</l>
<l n="c"><milestone unit="column" n="c"/>tadvyāpi ca na tatspr̥ṣṭam</l>
<l n="d"><milestone unit="column" n="d"/>ābhāti bhuvane ⏑ = <supplied reason="lost"><g ref="sym:doubleBar-ornate" type="punctuation">.</g></supplied></l>
</lg>
                   <lg n="2" met="anuṣṭubh">
<l n="a"><lb n="A2"/><milestone unit="column" n="a"/>…n… kṣetre</l>
<l n="b"><milestone unit="column" n="b"/>veśanissr̥tibhāg vibhuḥ</l>
<l n="c"><milestone unit="column" n="c"/>akṣīṇabhogamokṣārthaṁ</l>
<l n="d"><milestone unit="column" n="d"/>megherkka Iva rājate <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="3" met="anuṣṭubh">
<l n="a"><lb n="A3"/><milestone unit="column" n="a"/>[namām]y umāpatiṁ kāntāṁ</l>
<l n="b"><milestone unit="column" n="b"/>kāyesāmi vibhartti yaḥ</l>
<l n="c"><milestone unit="column" n="c"/>viśveṣāṁ pitarau bhāvaṁ</l>
<l n="d"><milestone unit="column" n="d"/>pratyakṣaṁ prathayan vibhuḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="4" met="anuṣṭubh">
<l n="a"><lb n="A4"/><milestone unit="column" n="a"/>[ca]turāsyan namasyāmi</l>
<l n="b"><milestone unit="column" n="b"/>śaṅke jāgartti yoniśam</l>
<l n="c"><milestone unit="column" n="c"/>vīkṣya viṣṇuṁ śrīyā suptaṁ</l>
<l n="d"><milestone unit="column" n="d"/>kṣīrāvdhau sr̥ṣṭirakṣayā <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="5" met="anuṣṭubh">
<l n="a"><lb n="A5"/><milestone unit="column" n="a"/>namo murāraye jyāyas</l>
<l n="b"><milestone unit="column" n="b"/>svavīryyan darśayann iva</l>
<l n="c"><milestone unit="column" n="c"/>svarvvāsivairiṇo daityāṁ</l>
<l n="d"><milestone unit="column" n="d"/>strīrūpeṇa jaghāna yaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="6" met="anuṣṭubh">
<l n="a"><lb n="A6"/><milestone unit="column" n="a"/>sarasvatīn name haṅsī</l>
<l n="b"><milestone unit="column" n="b"/>durgrahā līlayāmalā</l>
<l n="c" enjamb="yes"><milestone unit="column" n="c"/>lolā śavdaguṇe svaccha</l>
<l n="d"><milestone unit="column" n="d"/>-mānase yā ratā bhr̥śam <g ref="sym:bullet-hollow" type="punctuation">.</g> <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="7" met="anuṣṭubh">
<l n="a"><lb n="A7"/><milestone unit="column" n="a"/>Āsīt punnāgavarmmākhyaś</l>
<l n="b"><milestone unit="column" n="b"/>śaktimān rudravarmmaṇaḥ</l>
<l n="c" enjamb="yes"><milestone unit="column" n="c"/>narendralakṣmyāñ jāto 'dri</l>
<l n="d"><milestone unit="column" n="d"/>-putryāṁ guha Iveśvarāt <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="8" met="anuṣṭubh">
<l n="a"><lb n="A8"/><milestone unit="column" n="a"/>puṁsāṁ vīryyādyudāro yo</l>
<l n="b"><milestone unit="column" n="b"/>dehatrāṇasaho yudhi</l>
<l n="c"><milestone unit="column" n="c"/>yat tat punnāgavarmmeti</l>
<l n="d"><milestone unit="column" n="d"/>sūribhis sma nirucyate <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="9" met="anuṣṭubh">
<l n="a"><lb n="A9"/><milestone unit="column" n="a"/>saptadevakulagrāmaḥ</l>
<l n="b"><milestone unit="column" n="b"/>kṣoṇyāṁ sakṣetrasaṁsadi</l>
<l n="c"><milestone unit="column" n="c"/>pitr̥sīmikadattāyāṁ</l>
<l n="d"><milestone unit="column" n="d"/>yenākāri samantataḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="10" met="anuṣṭubh">
<l n="a"><lb n="A10"/><milestone unit="column" n="a"/>grāme rudrālayākhye yaḥ</l>
<l n="b"><milestone unit="column" n="b"/>kr̥te kiṅkarapūrite</l>
<l n="c"><milestone unit="column" n="c"/>śrībhadreśāsanaliṅga(ṁ)</l>
<l n="d"><milestone unit="column" n="d"/>sthāpayām āsa kalpitam <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="11" met="anuṣṭubh">
<l n="a"><lb n="A11"/><milestone unit="column" n="a"/>yaḥ prāsādādibhir bhūyas</l>
<l n="b"><milestone unit="column" n="b"/>samr̥ddhais taṁ samaskarot</l>
<l n="c"><milestone unit="column" n="c"/>tuṅgan tatākam akhanat</l>
<l n="d"><milestone unit="column" n="d"/>tatrollasitalāñchanam <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="12" met="anuṣṭubh">
<l n="a"><lb n="A12"/><milestone unit="column" n="a"/>viṣṇvaṅśasya pitus sapta</l>
<l n="b"><milestone unit="column" n="b"/>viṣṇupratikr̥tīr vyadhāt</l>
<l n="c"><milestone unit="column" n="c"/>bhaktyā yonekadeśasthā</l>
<l n="d"><milestone unit="column" n="d"/>bhuvanodīrṇṇaśaktikāḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="13" met="mālinī">
<l n="a"><lb n="A13"/>dviradapuranivāsaṁ pūjayonmīlya śambhuṁ<space/></l>
<l n="b">kr̥tavivudhavibhūtiṁ śaktimān prāṅgane yaḥ</l>
<l n="c"><lb n="A14"/>savihr̥tinijarūpaṁ mātr̥rūpañ ca devyā<space/></l>
<l n="d">Atulamahimahānes sthāpayām āsa mūrttim <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   
                   <lg n="14" met="anuṣṭubh">
<l n="a"><lb n="A15"/><milestone unit="column" n="a"/>tasya mātranvaye jātas</l>
<l n="b"><milestone unit="column" n="b"/>saṁvidācārarañjitaḥ</l>
<l n="c"><milestone unit="column" n="c"/>dharmmārthakāmadhaureyas</l>
<l n="d"><milestone unit="column" n="d"/>sarvvīyo guṇasaṁpadā <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="15" met="anuṣṭubh">
<l n="a"><lb n="A16"/><milestone unit="column" n="a"/>mahendrādristhiteḥ preyān</l>
<l n="b"><milestone unit="column" n="b"/>bhr̥tyaś śrījajayavarmmaṇaḥ</l>
<l n="c"><milestone unit="column" n="c"/>Uditoditavaṅśo yo</l>
<l n="d"><milestone unit="column" n="d"/>dhipo vyajanadhāriṇām <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="16" met="anuṣṭubh">
<l n="a"><lb n="A17"/><milestone unit="column" n="a"/>sasevānītaye yasmai</l>
<l n="b"><milestone unit="column" n="b"/>vāllabhyāsmayacetase</l>
<l n="c"><milestone unit="column" n="c"/>sarvvatra nijadeśenyāṁ</l>
<l n="d"><milestone unit="column" n="d"/>bhūyo bhūmin dadau nr̥paḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="17" met="anuṣṭubh">
<l n="a"><lb n="A18"/><milestone unit="column" n="a"/>tanmātranvayajaś śrīmān</l>
<l n="b"><milestone unit="column" n="b"/>vāsudeva Iva dviṣaḥ</l>
<l n="c"><milestone unit="column" n="c"/>vabhūva vāsudevākhyaḥ</l>
<l n="d"><milestone unit="column" n="d"/>kulatrāṇaparākramaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="18" met="anuṣṭubh">
<l n="a"><lb n="A19"/><milestone unit="column" n="a"/>śrīndravarmmākhyanr̥pateś</l>
<l n="b"><milestone unit="column" n="b"/>śrīyaśovarmmaṇaś ca yaḥ</l>
<l n="c"><milestone unit="column" n="c"/>(a)nuṣtheyaṁ vidhatte sma</l>
<l n="d"><milestone unit="column" n="d"/>rājanītiviśāradaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="19" met="anuṣṭubh">
<l n="a"><lb n="A20"/><milestone unit="column" n="a"/>tanmātranvayajāś śreṣthā</l>
<l n="b"><milestone unit="column" n="b"/>dharmmiṣthāḥ puruṣās trayaḥ</l>
<l n="c"><milestone unit="column" n="c"/>Apālayan kulan nyāyyam</l>
<l n="d"><milestone unit="column" n="d"/>akṣīṇakṣemarakṣaṇāt <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="20" met="anuṣṭubh">
<l n="a"><lb n="A21"/><milestone unit="column" n="a"/>śrīharṣavarmmaṇo rājye</l>
<l n="b"><milestone unit="column" n="b"/>ye ca śrīśānavarmmaṇaḥ</l>
<l n="c"><milestone unit="column" n="c"/>anutasthur anuṣtheyaṁ</l>
<l n="d"><milestone unit="column" n="d"/>kramāc chrījayavarmmaṇah <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="21" met="anuṣṭubh">
<l n="a"><lb n="A22"/><milestone unit="column" n="a"/>trayāṇāṁ yogradhiṣaṇo</l>
<l n="b"><milestone unit="column" n="b"/>manorūḍhanijāśayaḥ</l>
<l n="c"><milestone unit="column" n="c"/>śivaś śaraṇyaṁ mestīti</l>
<l n="d"><milestone unit="column" n="d"/>manaśśīva Itīritaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="22" met="anuṣṭubh">
<l n="a"><lb n="A23"/><milestone unit="column" n="a"/>yo vallabho bhāgineyīṁ</l>
<l n="b"><milestone unit="column" n="b"/>rājño rājendravarmmanaḥ</l>
<l n="c"><milestone unit="column" n="c"/>rupācārābhīrāmāṅgīṁ</l>
<l n="d"><milestone unit="column" n="d"/>prāṇākhyāṁ svāminīṁ vyadhāt <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="23" met="anuṣṭubh">
<l n="a"><lb n="A24"/><milestone unit="column" n="a"/>bhāgineyau mahātmānau</l>
<l n="b"><milestone unit="column" n="b"/>sarvvaśāstreṣv adhītinau</l>
<l n="c" enjamb="yes"><milestone unit="column" n="c"/>Akarod yājakau yaś śrī</l>
<l n="d"><milestone unit="column" n="d"/>-rājendreśvaraliṅgayoḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="24" met="anuṣṭubh">
<l n="a"><lb n="A25"/><milestone unit="column" n="a"/>śiṣṭānvayācāraguṇā</l>
<l n="b"><milestone unit="column" n="b"/>mr̥te rājendreśvarmmaṇi</l>
<l n="c"><milestone unit="column" n="c"/>sāpy abhyantaralekhinām</l>
<l n="d"><milestone unit="column" n="d"/>adhipā jayavarmmaṇaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="25" met="anuṣṭubh">
<l n="a"><lb n="A26"/>uditoditavaṅśau dvau<space/></l>
<l n="b">kavī śrījayavarmmaṇā</l>
<l n="c"><lb n="A27"/>nyayujyatāṁ śemuṣīddhau<space/></l>
<l n="d">hemaśr̥ṅgeśayājakau <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="26" met="anuṣṭubh">
<l n="a"><lb n="A28"/>Udīrṇṇakīrttayas teṣām<space/></l>
<l n="b">āsur mmātranvayoditāḥ</l>
<l n="c"><lb n="A29"/>vallabhāḥ pañca puruṣāḥ<space/></l>
<l n="d">bhr̥tyāś śrījayavarmmaṇaḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="27" met="anuṣṭubh">
<l n="a"><lb n="A30"/>teṣāṁ kavīśvarākhyo yo<space/></l>
<l n="b">vrahmacārī mahāmatiḥ</l>
<l n="c"><lb n="A31"/>nyayujyatāgnīkāryyeṣu<space/></l>
<l n="d">śreṣthaś śrījayavarmmaṇā <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="28" met="anuṣṭubh"><milestone type="pagelike" unit="face" n="B"/><label xml:lang="eng">Face B</label>
<l n="a"><lb n="B1"/><milestone unit="column" n="a"/>Atha śrīsūryyavarmmāsīt</l>
<l n="b"><milestone unit="column" n="b"/>sāmrād rājanvatīdharaḥ</l>
<l n="c"><milestone unit="column" n="c"/>mātranvayod(i)t(as) t(as)ya</l>
<l n="d"><milestone unit="column" n="d"/>= = = = ⏑ - ⏑ = <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="29" met="anuṣṭubh">
<l n="a"><lb n="B2"/><milestone unit="column" n="a"/>roṣānalād dhruvaṁ śambhor</l>
<l n="b"><milestone unit="column" n="b"/>anaṅgaṁ vīkṣya manmatham</l>
<l n="c"><milestone unit="column" n="c"/>kāntopamāṁ nayan dhātā</l>
<l n="d"><milestone unit="column" n="d"/>n(ir)mmame (n)u ⏑ - ⏑ = <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="30" met="anuṣṭubh">
<l n="a"><lb n="B3"/><milestone unit="column" n="a"/>tejasvibhūbhr̥jjitaye</l>
<l n="b"><milestone unit="column" n="b"/>yasya yāne bhiyā dhruvam</l>
<l n="c"><milestone unit="column" n="c"/>ravir antardadhe śailāḥ</l>
<l n="d"><milestone unit="column" n="d"/>gajavyājena vā ⏑ = <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="31" met="anuṣṭubh">
<l n="a"><lb n="B4"/><milestone unit="column" n="a"/>dhūmo yasyādhvare dharmmyān</l>
<l n="b"><milestone unit="column" n="b"/>dhuran dhr̥tavato bhuvaḥ</l>
<l n="c"><milestone unit="column" n="c"/>naivāmalinayad vyoma</l>
<l n="d"><milestone unit="column" n="d"/>yaśopi khyātabhūbhr̥tā[m] <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="32" met="anuṣṭubh">
<l n="a"><lb n="B5"/><milestone unit="column" n="a"/>kr̥ṣṇāgrāhī kulahite</l>
<l n="b"><milestone unit="column" n="b"/>pātayan bhīṣmam āhave</l>
<l n="c"><milestone unit="column" n="c"/>yuktaṁ yo 'pi arjunayaśāḥ</l>
<l n="d"><milestone unit="column" n="d"/>bhīmasenohitāstrakr̥t <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="33" met="anuṣṭubh">
<l n="a"><lb n="B6"/><milestone unit="column" n="a"/>Aho yo tharvvaniṣṇāto</l>
<l n="b"><milestone unit="column" n="b"/>yogāsaktamanā bhr̥tam</l>
<l n="c"><milestone unit="column" n="c"/>vavan(dh)a niścalaṁ lokān</l>
<l n="d"><milestone unit="column" n="d"/>niśśeṣān saptatantubhiḥ <g ref="sym:doubleBar-ornate" type="punctuation">.</g></l>
</lg>
                   <lg n="34" met="anuṣṭubh">
<l n="a"><lb n="B7"/><milestone unit="column" n="a"/>pāṇinīyamate vidvān</l>
<l n="b"><milestone unit="column" n="b"/>nitarām api sattamaḥ</l>
<l n="c"><milestone unit="column" n="c"/>parārthotpādane dravye</l>
